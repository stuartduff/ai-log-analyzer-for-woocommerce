<?xml version="1.0"?>
<ruleset name="AI Log Analyzer">
	<description>PHPCS ruleset for the AI Log Analyzer plugin.</description>

	<rule ref="WordPress"/>

	<!-- Declare custom capabilities so the Capabilities sniff doesn't flag them. -->
	<rule ref="WordPress.WP.Capabilities">
		<properties>
			<property name="custom_capabilities" type="array">
				<element value="manage_woocommerce"/>
				<element value="prompt_ai"/>
			</property>
		</properties>
	</rule>

	<config name="minimum_supported_wp_version" value="7.0"/>
	<config name="text_domain" value="ai-log-analyzer-for-woocommerce"/>
	<config name="prefixes" value="ailwc"/>

	<file>ai-log-analyzer-for-woocommerce.php</file>
	<file>includes/</file>
	<file>admin/</file>

	<arg name="extensions" value="php"/>
	<arg name="colors"/>
	<arg value="ps"/>

	<exclude-pattern>vendor/*</exclude-pattern>
	<exclude-pattern>node_modules/*</exclude-pattern>
	<exclude-pattern>build/*</exclude-pattern>
	<exclude-pattern>tests/*</exclude-pattern>
</ruleset>
